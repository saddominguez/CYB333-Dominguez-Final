import re
import getpass


# Common weak patterns
PATTERNS = ["password", "123", "qwerty", "admin", "letmein"]

# Displays password requirements
def password_requirements():
    print("Password Requirements:")
    print("- 12 characters minimum")
    print("- One uppercase letter required")
    print("- One lowercase letter required")
    print("- One number required")
    print("- One special character required")
    print("- Should not contain common words (ex: password, 123)")
    print("-" * 26)

# Evaluates the strength of the password and provides suggestions for improvement
def password_strength(password):
    suggestions = []
    score = 0

    # Checks the length of the password
    if len(password) >= 12:
        score += 25
    else:
        suggestions.append("Password must be at least 12 characters long.")

    # Checks for uppercase letters
    if re.search(r"[A-Z]", password):
        score += 15
    else:
        suggestions.append("Password must contain at least one uppercase letter.")

    # Checks for lowercase letters
    if re.search(r"[a-z]", password):
        score += 15
    else:
        suggestions.append("Password must contain at least one lowercase letter.")

    # Checks for numbers
    if re.search(r"[0-9]", password):
        score += 15
    else:
        suggestions.append("Password must contain at least one number.")

    # Checks for special characters
    if re.search(r"[!@#$%^&*()-_=+]", password):
        score += 15
    else:
        suggestions.append("Password must contain at least one special character.")

    # Checks for common patterns/words
    if any(word in password.lower() for word in PATTERNS):
        suggestions.append("Password contains a common pattern (ex: 'password', '123').")
        return False, 0, "Weak", suggestions

    # Does not allow repeating characters
    if re.search(r"(.)\1{2,}", password):
        score -= 10
        suggestions.append("Do not repeat the same character multiple times.")

    # Ensures the scores stay between 0 and 100
    if score < 0:
        score = 0
    if score > 100:
        score = 100

    # Analyze password strength based on score
    if score >= 80:
        strength = "Strong"
    elif score >= 50:
        strength = "Moderate"
    else:
        strength = "Weak"

    # Determine if the password is valid based on a minimum score of 50
    is_valid = score >= 50

    return is_valid, score, strength, suggestions


def main():
    print("Password Strength")
    print("-" * 30)

    # Shows the password requirements before user input
    password_requirements()

    # Loop until a valid password is entered
    while True:
        # Hides users password input
        password = getpass.getpass("Enter password: ")

        # Evaluates the password strength and validity
        is_valid, score, strength, suggestions = password_strength(password)

        # Displays the password strength score and strength level
        print(f"\nScore: {score}/100")
        print(f"Strength: {strength}")

        # Check if the password meets the minimum requirements
        if is_valid:
            print("\nPassword meets all requirements.")
            break
        else:
            print("\nPassword does not meet the requirements.")

        # Provides suggestions for improving the password if it does not meet the requirements
        if suggestions:
            print("\nSuggestions:")
            for item in suggestions:
                print(f"- {item}")
        else:
            # If there are no suggestions, password meets all requirements
            print("\nPassword meets all requirements.")

        # Prompts the user to try again if the password is not valid
        print("\n" + "-" * 30)
        print("Try again")

# Run the program
if __name__ == "__main__":
    main()
